# Server — Production Environment Variables
# Copy this file to .env and fill in your real values

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production
LOG_LEVEL=info

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
# Single domain:
#   CLIENT_ORIGIN=https://capture-grid.vercel.app
# Multiple domains (e.g. custom domain + Vercel preview):
#   CLIENT_ORIGIN=https://capture-grid.vercel.app,https://www.yourdomain.com
CLIENT_ORIGIN=https://your-frontend.vercel.app
