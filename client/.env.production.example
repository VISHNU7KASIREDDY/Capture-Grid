# Client — Production Environment Variables
# Copy this file to .env.production.local and fill in your backend URL

# WebSocket / API server URL — must match your deployed backend
# Example (Railway):   VITE_SERVER_URL=https://capture-grid-server.up.railway.app
# Example (Render):    VITE_SERVER_URL=https://capture-grid.onrender.com
# Example (custom):    VITE_SERVER_URL=https://api.yourdomain.com
VITE_SERVER_URL=https://your-backend.up.railway.app
